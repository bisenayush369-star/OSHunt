generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  githubUsername String?
  
  firstName      String?
  lastName       String?
  newsletter     Boolean   @default(false)
  useCase        String?
  onboarded      Boolean   @default(false)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  accounts       Account[]
  sessions       Session[]
  contributions  Contribution[]
  streak         Streak?
  savedStack     SavedStack?
  bookmarks      Bookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contribution {
  id         String   @id @default(cuid())
  userId     String
  repoName   String
  repoUrl    String
  issueTitle String
  issueUrl   String
  issueId    String
  difficulty String
  language   String
  solvedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, issueId])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String   @unique
  current      Int      @default(0)
  longest      Int      @default(0)
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedStack {
  id         String   @id @default(cuid())
  userId     String   @unique
  language   String   @default("JavaScript")
  difficulty String   @default("easy")
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
}

model ApiProvider {
  id           String   @id @default(cuid())
  name         String   @unique // e.g., "GEMINI", "NVIDIA", "OPENROUTER"
  requestsUsed Int      @default(0)
  maxLimit     Int      // Your monthly/daily free tier limit
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}